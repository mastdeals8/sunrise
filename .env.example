# Sunrise Media ERP — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ─────────────────────────────────────────────────────────────────
# Supabase / PostgreSQL connection string (use pooler URL for production).
DATABASE_URL=""

# JWT signing secret — at least 32 random characters.
# Generate: openssl rand -hex 32
JWT_SECRET=""

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Sunrise Media ERP"
NODE_ENV="development"

# ── Port ─────────────────────────────────────────────────────────────────────
# Railway/Render/Fly inject PORT automatically. Only set for local dev.
# PORT=5000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed cross-origin origins. Leave blank for same-domain.
# CORS_ORIGINS="https://your-app.railway.app"

# ── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_PROVIDER="local"
# Absolute path to uploads directory. Defaults to <project-root>/uploads.
# On Railway/Render/Fly: set to your mounted volume path, e.g. /app/uploads
UPLOAD_DIR=""

# ── Optional ─────────────────────────────────────────────────────────────────
# UPLOAD_MAX_BYTES=26214400
# TELEGRAM_WEBHOOK_SECRET=""
# CHROME_EXECUTABLE="/usr/bin/chromium-browser"
# PUBLIC_BASE_URL="http://localhost:5000"
