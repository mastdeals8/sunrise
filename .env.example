# Copy to .env and fill in your values.
# PORT is optional — cloud environments (Bolt, Replit, Railway, etc.)
# inject PORT automatically. Omit it here to let the platform decide.
# For local development the server falls back to port 5000.

DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
JWT_SECRET="replace-with-at-least-32-random-characters"
SESSION_SECRET="replace-with-at-least-32-random-characters"
APP_NAME="Sunrise Media ERP"
UPLOAD_PROVIDER="local"
# CORS_ORIGINS="https://your-domain.com"
