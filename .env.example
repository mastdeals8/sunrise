# Sunrise Media ERP — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database ─────────────────────────────────────────────────────────────────
# Supabase connection string. Use the "pooler" URL for production.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
# At least 32 random characters. Generate: openssl rand -hex 32
JWT_SECRET="replace-with-at-least-32-random-characters"

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME="Sunrise Media ERP"
NODE_ENV="production"

# ── Port (optional) ──────────────────────────────────────────────────────────
# Cloud platforms (Railway, Render, Fly.io) inject PORT automatically.
# Only set this for local dev if you need a specific port.
# PORT=5000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed cross-origin origins.
# Leave blank for same-domain deployments (most common).
# CORS_ORIGINS="https://your-app.railway.app,https://your-custom-domain.com"

# ── Uploads ──────────────────────────────────────────────────────────────────
# Upload provider: "local" stores files in /uploads on disk.
# IMPORTANT: On Railway/Render/Fly.io, attach a persistent Volume to the
# /uploads path or files will be lost on redeploy.
# Future option: "gcs" or "s3" for cloud storage.
UPLOAD_PROVIDER="local"

# Absolute path to the uploads directory.
# Defaults to <project-root>/uploads when unset.
# On Railway/Render/Fly.io, set this to the mounted volume path, e.g.:
# UPLOAD_DIR=/app/uploads
# UPLOAD_DIR=/data/uploads

# Maximum upload file size in bytes. Default: 26214400 (25 MB).
# UPLOAD_MAX_BYTES=26214400

# ── PDF Generation (Invoice Packet) ──────────────────────────────────────────
# Path to Chrome/Chromium for playwright-based PDF rendering.
# Auto-detected on macOS. On Linux hosting, install chromium:
#   apt-get install -y chromium-browser
# Then either set this or let auto-detection find /usr/bin/chromium-browser.
# CHROME_EXECUTABLE="/usr/bin/chromium-browser"

# Self-render base URL for playwright. Only needed if auto-detection of
# localhost:PORT doesn't work in your hosting environment.
# PUBLIC_BASE_URL="http://localhost:5000"

# ── Telegram (optional) ──────────────────────────────────────────────────────
# TELEGRAM_WEBHOOK_SECRET="your-webhook-secret"
